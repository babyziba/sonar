# Sonr — example environment configuration
#
# Copy this file to `.env` and edit values to override the built-in defaults.
# CLI flags passed to `python src/sonr.py` always take precedence over env
# vars, and env vars take precedence over the defaults compiled into the
# script.
#
# Sonr does not auto-load .env. The simplest way to apply it:
#   set -a; source .env; set +a
#   python src/sonr.py

# YOLO11 model file or name. Auto-downloads on first use if not on disk.
SONR_MODEL=yolo11n.pt

# Video source. Use "0" for the default webcam, "1"+ for additional cameras,
# or a path to a video file.
SONR_SOURCE=0

# Inference device. Leave blank to let Ultralytics auto-select (mps on Apple
# Silicon, cuda on NVIDIA, cpu otherwise). Override with "cpu", "cuda", or
# "mps".
SONR_DEVICE=

# YOLO confidence threshold. Lower values (e.g. 0.5) catch more objects but
# may speak about hands or partial detections. Higher values are quieter.
SONR_CONF=0.75
